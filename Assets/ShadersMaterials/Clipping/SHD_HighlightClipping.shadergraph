    "m_SourceType": 1,
    "m_FunctionName": "PixelClip",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float3 directionToPixel = WorldPos - PlanePos;\n\nfloat distance = dot(directionToPixel, NormalPlane);\n\nclip(distance);\n\nOut = 1.0;\n"
}

